# Exemplo de variáveis de ambiente (12-factor — não comitar segredos reais).
# Back-end (prefixo GOLDENDATA_)
GOLDENDATA_ENVIRONMENT=dev
GOLDENDATA_DATABASE_URL=postgresql://goldendata:goldendata@localhost:5432/goldendata
GOLDENDATA_CORS_ORIGINS=http://localhost:5173

# Modo de autenticação: none (demo) | local (e-mail+senha) | oidc (Keycloak) | supabase (Supabase Auth)
GOLDENDATA_AUTH_MODE=none
# Modo supabase: valida o JWT (ES256) do Supabase via JWKS; papéis em app_metadata.roles.
# GOLDENDATA_OIDC_ISSUER=https://<ref>.supabase.co/auth/v1
# GOLDENDATA_OIDC_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# GOLDENDATA_OIDC_AUDIENCE=authenticated
# Obrigatório no modo local: segredo HS256 dos tokens emitidos pelo backend.
# GOLDENDATA_AUTH_SECRET=troque-por-um-segredo-forte

# Modo oidc (Keycloak — produção institucional):
# GOLDENDATA_OIDC_ISSUER=http://localhost:8080/realms/tjmg
# GOLDENDATA_OIDC_JWKS_URL=http://localhost:8080/realms/tjmg/protocol/openid-connect/certs
# GOLDENDATA_OIDC_AUDIENCE=goldendata-api
# NUNCA habilitar em produção — ignora a verificação de assinatura do JWT.
GOLDENDATA_AUTH_DEV_INSECURE=false

# Servidor MCP (Model Context Protocol) — permite a IAs operarem a plataforma.
GOLDENDATA_MCP_ENABLED=true
# Token de acesso ao MCP (Claude Code CLI / Desktop). VAZIO = aberto (somente demo).
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Aceita múltiplos tokens separados por vírgula (rotação).
GOLDENDATA_MCP_TOKEN=
# Hosts permitidos no header Host do MCP (anti DNS-rebinding). Atrás de proxy: o domínio público.
GOLDENDATA_MCP_ALLOWED_HOSTS=
# OAuth do MCP — necessário para o connector do claude.ai (web/Desktop). Liga um
# Authorization Server embutido (DCR + PKCE). O token estático acima continua
# válido para o CLI. Exige as três variáveis abaixo definidas.
GOLDENDATA_MCP_OAUTH_ENABLED=false
GOLDENDATA_MCP_PUBLIC_URL=
# Segredo HS256 dos tokens OAuth; gere com: openssl rand -hex 32
GOLDENDATA_MCP_OAUTH_JWT_SECRET=

# Front-end (prefixo VITE_) — embutidas em BUILD time
VITE_API_URL=http://localhost:8000
VITE_AUTH_MODE=none
# Modo supabase (login e-mail+senha):
# VITE_AUTH_MODE=supabase
# VITE_SUPABASE_URL=https://<ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon/publishable key>
# Modo oidc:
# VITE_AUTH_MODE=oidc
# VITE_OIDC_AUTHORITY=http://localhost:8080/realms/tjmg
# VITE_OIDC_CLIENT_ID=goldendata-spa
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/
