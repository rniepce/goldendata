{
  "realm": "tjmg",
  "enabled": true,
  "sslRequired": "none",
  "loginTheme": "keycloak",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "coordenador_comite", "description": "Coordenador/Comitê de IA" },
      { "name": "owner_ferramenta", "description": "Responsável (owner) da ferramenta/agente" },
      { "name": "avaliador", "description": "Avaliador human-in-the-loop (servidor/magistrado)" },
      { "name": "auditor_dpo", "description": "Auditor / Encarregado (DPO)" },
      { "name": "admin", "description": "Administrador da plataforma" }
    ]
  },
  "clients": [
    {
      "clientId": "goldendata-spa",
      "name": "goldendata SPA (front-end)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "protocolMappers": [
        {
          "name": "audience-goldendata-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "goldendata-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "coordenador",
      "enabled": true,
      "email": "coordenador@tjmg.jus.br",
      "firstName": "Coordenador",
      "lastName": "Comitê de IA",
      "credentials": [{ "type": "password", "value": "coordenador", "temporary": false }],
      "realmRoles": ["coordenador_comite"]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "owner",
      "enabled": true,
      "email": "owner@tjmg.jus.br",
      "firstName": "Responsável",
      "lastName": "Ferramenta",
      "credentials": [{ "type": "password", "value": "owner", "temporary": false }],
      "realmRoles": ["owner_ferramenta"]
    },
    {
      "id": "33333333-3333-3333-3333-333333333333",
      "username": "avaliador",
      "enabled": true,
      "email": "avaliador@tjmg.jus.br",
      "firstName": "Avaliador",
      "lastName": "Servidor",
      "credentials": [{ "type": "password", "value": "avaliador", "temporary": false }],
      "realmRoles": ["avaliador"]
    },
    {
      "id": "44444444-4444-4444-4444-444444444444",
      "username": "dpo",
      "enabled": true,
      "email": "dpo@tjmg.jus.br",
      "firstName": "Auditor",
      "lastName": "DPO",
      "credentials": [{ "type": "password", "value": "dpo", "temporary": false }],
      "realmRoles": ["auditor_dpo"]
    },
    {
      "id": "55555555-5555-5555-5555-555555555555",
      "username": "admin-app",
      "enabled": true,
      "email": "admin@tjmg.jus.br",
      "firstName": "Administrador",
      "lastName": "Plataforma",
      "credentials": [{ "type": "password", "value": "admin-app", "temporary": false }],
      "realmRoles": ["admin"]
    }
  ]
}
