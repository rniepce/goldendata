# URL base da API FastAPI do back-end (sem barra final). O cliente acrescenta o prefixo /api.
VITE_API_URL=http://localhost:8000

# Authority OIDC do Keycloak (realm). Ex.: https://sso.tjmg.jus.br/realms/goldendata
VITE_OIDC_AUTHORITY=http://localhost:8080/realms/goldendata

# Client ID público (SPA) registrado no Keycloak
VITE_OIDC_CLIENT_ID=goldendata-frontend

# URI de redirecionamento pós-login (deve estar cadastrada no Keycloak)
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
